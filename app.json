{
  "expo": {
    "name": "MQTT Dashboard",
    "slug": "mqtt-dashboard",
    "version": "1.0.0",
    "scheme": "mqttdashboard",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.mqttdashboard"
    },
    "android": {
      "package": "com.yourname.mqttdashboard",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f35a29e-553d-4306-8e45-4c845e4bd99d"
      }
    }
  }
}
